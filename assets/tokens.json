{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "caleida": {
    "meta": {
      "system": "The Sunday Kitchen",
      "version": "1.0.0",
      "doctrine": "Kaleidoscope in the logo only. Cal speaks in the warm roast. The Invisible Work screen is a mirror, never a scoreboard. Household companion, not a task app."
    },
    "color": {
      "surface": {
        "paper":      { "value": "#F7F0E3", "type": "color", "description": "page / app surface (base of stock gradient)" },
        "paperDeep":  { "value": "#F0E7D3", "type": "color", "description": "foot of the paper-stock gradient" },
        "card":       { "value": "#FFFDF6", "type": "color", "description": "panels" },
        "note":       { "value": "#FFFDF3", "type": "color", "description": "Cal's note paper" }
      },
      "ink": {
        "ink":   { "value": "#2A211B", "type": "color", "description": "headings/primary text — 14:1 on paper (AAA)" },
        "body":  { "value": "#4A4038", "type": "color", "description": "body copy — 8.9:1 on paper (AAA)" },
        "muted": { "value": "#9C8E7E", "type": "color", "description": "captions, meta" },
        "line":  { "value": "#E8DEC9", "type": "color", "description": "hairlines" },
        "line2": { "value": "#DFD3BC", "type": "color", "description": "stronger dividers" }
      },
      "pigment": {
        "terracotta":     { "value": "#C05330", "type": "color", "description": "THE signature — display, fills, buttons" },
        "terracottaDeep": { "value": "#A94525", "type": "color", "description": "small terracotta text / press — 5.2:1 AA" },
        "salmon":         { "value": "#E0825E", "type": "color", "description": "terracotta tint, illustration fills" },
        "teal":           { "value": "#1F8175", "type": "color", "description": "Cal acts / confirms" },
        "tealDeep":       { "value": "#186B60", "type": "color", "description": "small teal text — 5.6:1 AA" },
        "gold":           { "value": "#D9A23A", "type": "color", "description": "highlights (small areas only)" },
        "goldSoft":       { "value": "#F3E2B8", "type": "color", "description": "sticky labels" },
        "goldInk":        { "value": "#8A5F10", "type": "color", "description": "text on gold" }
      },
      "onColor": {
        "onTerracotta": { "value": "#FFFDF8", "type": "color", "description": "white on terra — 4.6:1 AA" },
        "onTeal":       { "value": "#FFFDF8", "type": "color", "description": "white on teal — 4.7:1 AA" }
      },
      "dark": {
        "espresso":       { "value": "#211913", "type": "color", "description": "night surface (not black)" },
        "espressoPanel":  { "value": "#2A2017", "type": "color" },
        "linen":          { "value": "#F4EDE0", "type": "color", "description": "text on espresso" },
        "terracottaGlow": { "value": "#D77E57", "type": "color", "description": "terracotta on dark" },
        "tealGlow":       { "value": "#7FB6A6", "type": "color", "description": "teal on dark" }
      }
    },
    "gradient": {
      "surface":        { "value": "linear-gradient(178deg, #F7F0E3, #F0E7D3)", "type": "gradient" },
      "glazeTerracotta":{ "value": "linear-gradient(165deg, #C96F49, #B65C38 55%, #A04E2C)", "type": "gradient" },
      "glazeTeal":      { "value": "linear-gradient(165deg, #2E9488, #1F8175 55%, #186B60)", "type": "gradient" },
      "btnTerracotta":  { "value": "linear-gradient(#CF6238, #C05330 55%, #A94525)", "type": "gradient" },
      "labelGold":      { "value": "linear-gradient(#FBEFD2, #F3E2B8)", "type": "gradient" }
    },
    "font": {
      "family": {
        "logo":    { "value": "Bricolage Grotesque", "type": "fontFamily", "description": "the logotype / wordmark ONLY — warm grotesque; the diamond carries the craft" },
        "display": { "value": "Fraunces", "type": "fontFamily", "description": "editorial headlines only (440-560)" },
        "ui":      { "value": "Plus Jakarta Sans", "type": "fontFamily", "description": "body + UI" },
        "cal":     { "value": "Shantell Sans", "type": "fontFamily", "description": "Cal's voice — his handwriting (chat bubbles + taped notes); confirms/UI stay ui" }
      },
      "weight": {
        "body":    { "value": 400, "type": "fontWeight" },
        "medium":  { "value": 500, "type": "fontWeight", "description": "Cal's roast" },
        "bold":    { "value": 700, "type": "fontWeight", "description": "Cal's confirm" },
        "display": { "value": 520, "type": "fontWeight", "description": "Fraunces display, lightened from 620" },
        "logo":    { "value": 600, "type": "fontWeight", "description": "Bricolage logotype" }
      },
      "size": {
        "display": { "value": "clamp(40px, 6.6vw, 74px)", "type": "dimension" },
        "h1":      { "value": "clamp(32px, 5vw, 52px)", "type": "dimension" },
        "h2":      { "value": "clamp(26px, 3.4vw, 36px)", "type": "dimension" },
        "h3":      { "value": "20px", "type": "dimension" },
        "body":    { "value": "16px", "type": "dimension" },
        "small":   { "value": "14px", "type": "dimension" },
        "caption": { "value": "12.5px", "type": "dimension" }
      },
      "leading": {
        "body":  { "value": 1.65, "type": "number" },
        "tight": { "value": 1.1, "type": "number" }
      }
    },
    "radius": {
      "card":  { "value": "14px", "type": "dimension" },
      "btn":   { "value": "12px", "type": "dimension" },
      "input": { "value": "10px", "type": "dimension" },
      "note":  { "value": "3px", "type": "dimension" },
      "pill":  { "value": "999px", "type": "dimension" },
      "icon":  { "value": "18px", "type": "dimension" }
    },
    "shadow": {
      "1":     { "value": "0 1px 2px rgba(58,40,26,.10)", "type": "shadow", "description": "rest" },
      "2":     { "value": "0 1px 2px rgba(58,40,26,.10), 0 8px 18px rgba(58,40,26,.10)", "type": "shadow", "description": "raised" },
      "3":     { "value": "0 1px 2px rgba(58,40,26,.12), 0 16px 34px rgba(58,40,26,.13)", "type": "shadow", "description": "lifted" },
      "inset": { "value": "inset 0 1px 3px rgba(58,40,26,.14)", "type": "shadow", "description": "pressed inputs" },
      "press": { "value": "0 1px 0 rgba(255,255,255,.30) inset, 0 -2px 0 rgba(90,30,10,.30) inset", "type": "shadow", "description": "button depth" }
    },
    "space": {
      "1": { "value": "4px", "type": "dimension" },
      "2": { "value": "8px", "type": "dimension" },
      "3": { "value": "12px", "type": "dimension" },
      "4": { "value": "16px", "type": "dimension" },
      "5": { "value": "20px", "type": "dimension" },
      "6": { "value": "24px", "type": "dimension" },
      "8": { "value": "32px", "type": "dimension" },
      "10": { "value": "40px", "type": "dimension" },
      "14": { "value": "56px", "type": "dimension" },
      "container": { "value": "1060px", "type": "dimension" }
    },
    "motion": {
      "ease":     { "value": "cubic-bezier(0.22, 0.61, 0.36, 1)", "type": "cubicBezier", "description": "ease-out, drawer-soft" },
      "durFast":  { "value": "160ms", "type": "duration" },
      "dur":      { "value": "220ms", "type": "duration" }
    }
  }
}
